{
	"name": "@roastery-capsules/auth",
	"description": "Authentication and session management capsule for the Roastery CMS ecosystem, featuring JWT tokens, rate-limited login, and route protection guards.",
	"version": "0.0.1",
	"type": "module",
	"author": {
		"name": "Alan Reis",
		"email": "alanreisanjo@gmail.com",
		"url": "https://github.com/Hoyasumii"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/roastery-cms/capsules-auth"
	},
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*/index.d.ts"
			]
		}
	},
	"keywords": [
		"authentication",
		"jwt",
		"session-management",
		"rate-limiting",
		"auth-guard",
		"elysia",
		"roastery-cms",
		"access-token",
		"login"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*/index.d.ts",
			"import": "./dist/*/index.js",
			"require": "./dist/*/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "biome check --fix && tsup 'src/**/index.ts' --format cjs,esm --dts --tsconfig tsconfig.build.json --clean",
		"test:unit": "bun test --env-file=.env.testing",
		"test:coverage": "bun test --env-file=.env.testing --coverage",
		"setup": "bun run build && bun link",
		"prepare": "husky || true",
		"knip": "knip"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"husky": "^9.1.7",
		"knip": "^5.85.0"
	},
	"peerDependencies": {
		"@types/bun": "latest",
		"tsup": "^8.5.1",
		"typescript": "^5"
	},
	"dependencies": {
		"jose": "^6.2.0",
		"@roastery-adapters/cache": "^0.0.4",
		"@roastery/barista": "^0.0.5",
		"@roastery/beans": "^0.0.2",
		"@roastery/seedbed": "^0.0.2",
		"@roastery/terroir": "^0.0.9"
	}
}
